@base <https://w3id.org/valueflows/ont/vf> .
@prefix as: <https://www.w3.org/ns/activitystreams#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dtype: <http://www.linkedmodel.org/schema/dtype#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spdxl: <https://spdx.org/licenses/> .
@prefix spdxt: <http://spdx.org/rdf/terms#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix vf: <https://w3id.org/valueflows/ont/vf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  a owl:Ontology ;
  owl:versionInfo "0.13" ;
  owl:versionIRI <https://w3id.org/valueflows/ont/0.13/vf> ;
  cc:license "https://creativecommons.org/licenses/by-sa/4.0/" ;
  dcterms:description "A vocabulary for the distributed economic networks of the next economy, to coordinate the creation, distribution, and exchange of economic resources" ;
  dcterms:license "https://creativecommons.org/licenses/by-sa/4.0/" ;
  dcterms:source "https://codeberg.org/valueflows/pages/src/branch/main/assets/all_vf.TTL" ;
  dcterms:status <http://purl.org/adms/status/UnderDevelopment> ;
  dcterms:title "Valueflows Ontology" ;
  dcterms:type <http://purl.org/adms/assettype/Ontology> ;
  spdxt:licenseDeclared spdxl:CC-BY-SA-4.0 ;
  vann:preferredNamespacePrefix "vf" ;
  vann:preferredNamespaceUri "https://w3id.org/valueflows/ont/vf#" ;
  .

vf:AccountableEffect
  a owl:Class ;
  rdfs:label "Accountable Effect"@en ;
  rdfs:comment "The action has this effect on an inventoried resource primary accountable agent."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:AccountingEffect
  a owl:Class ;
  rdfs:label "Accounting Effect"@en ;
  rdfs:comment "The action has this effect on an inventoried resource accounting quantity."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:Action
  a owl:Class ;
  rdfs:label "Action"@en ;
  rdfs:comment "An action verb defining the kind of flow and its behavior."@en ;
  vs:term_status "stable" ;
  vf:layer vf:knowledge ;
  .

vf:Agent
  a owl:Class ;
  rdfs:label "Agent"@en ;
  rdfs:comment "An entity that can commit to and/or perform economic and/or ecological activity under its own power or authority."@en ;
  rdfs:seeAlso foaf:Agent ;
  vs:term_status "stable" ;
  vf:layer vf:observation ;
  .

vf:AgentRelationship
  a owl:Class ;
  rdfs:label "Agent Relationship"@en ;
  rdfs:comment "An ongoing voluntary association between 2 agents of any kind."@en ;
  rdfs:seeAlso as:Relationship ;
  vs:term_status "stable" ;
  vf:layer vf:observation ;
  .

vf:AgentRelationshipRole
  a owl:Class ;
  rdfs:label "Agent Relationship Role"@en ;
  rdfs:comment "A relationship role defining the kind of association one agent can have with another."@en ;
  vs:term_status "stable" ;
  vf:layer vf:knowledge ;
  .

vf:Agreement
  a owl:Class ;
  rdfs:label "Agreement"@en ;
  rdfs:comment "Reciprocal relations among economic agents."@en ;
  vs:term_status "stable" ;
  vf:layer vf:plan ;
  .

vf:AgreementBundle
  a owl:Class ;
  rdfs:label "Agreement Bundle"@en ;
  rdfs:comment "A grouping of agreements to bundle detailed line item reciprocity."@en ;
  vs:term_status "unstable" ;
  vf:layer vf:plan ;
  .

vf:Claim
  a owl:Class ;
  rdfs:label "Claim"@en ;
  rdfs:comment "A claim for a future economic event(s) in reciprocity for an economic event that already occurred. For example, a claim for payment for goods received."@en ;
  vs:term_status "testing" ;
  vf:layer vf:observation ;
  .

vf:Commitment
  a owl:Class ;
  rdfs:label "Commitment"@en ;
  rdfs:comment "A planned economic flow that has been promised by an agent to another agent."@en ;
  vs:term_status "stable" ;
  vf:layer vf:plan ;
  .

vf:ConceptLayer
  a owl:Class ;
  rdfs:label "Concept Layer"@en ;
  rdfs:comment "The conceptual layers of the ontology, used to document the model."@en ;
  vs:term_status "unstable" ;
  .

vf:ContainedEffect
  a owl:Class ;
  rdfs:label "Contained Effect"@en ;
  rdfs:comment "The action has this effect on an inventoried resource contained in resource."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:CreateResource
  a owl:Class ;
  rdfs:label "Create Resource"@en ;
  rdfs:comment "The action can create an economic resource."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:EcologicalAgent
  a owl:Class ;
  rdfs:label "Ecological Agent"@en ;
  rdfs:comment "A non-human being; or a functional group of non-human beings; or an ecosystem of living beings that includes non-humans; but it has agency, it causes effects on the world. For example, a lake provides habitat for living things and effects weather."@en ;
  rdfs:subClassOf vf:Agent ;
  vs:term_status "testing" ;
  vf:layer vf:observation ;
  .

vf:EconomicEvent
  a owl:Class ;
  rdfs:label "Economic Event"@en ;
  rdfs:comment "An observed economic flow, as opposed to a flow planned to happen in the future. This could reflect a change in the quantity of an economic resource. It is also defined by its behavior in relation to the economic resource (see vf:action)"@en ;
  vs:term_status "stable" ;
  vf:layer vf:observation ;
  .

vf:EconomicResource
  a owl:Class ;
  rdfs:label "Economic Resource"@en ;
  rdfs:comment "Observable economic or environmental inputs to or outputs from processes, which agents agree should be accounted for."@en ;
  vs:term_status "stable" ;
  vf:layer vf:observation ;
  .

vf:EventQuantity
  a owl:Class ;
  rdfs:label "Event Quantity"@en ;
  rdfs:comment "The action involves the event resource quantity, event quantity, or both."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:InputOutput
  a owl:Class ;
  rdfs:label "Input/Output"@en ;
  rdfs:comment "The action is an input or output of a process, or not applicable to a process."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:Intent
  a owl:Class ;
  rdfs:label "Intent"@en ;
  rdfs:comment "A proposed or planned or estimated economic flow, which could become a commitment and/or economic event."@en ;
  vs:term_status "stable" ;
  vf:layer vf:plan ;
  .

vf:LocationEffect
  a owl:Class ;
  rdfs:label "Location Effect"@en ;
  rdfs:comment "The action has this effect on an inventoried resource current location."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:Measure
  a owl:Class ;
  rdfs:label "Measure"@en ;
  rdfs:comment "A quantity expressed as a numeric value with a unit of measure."@en ;
  rdfs:subClassOf om:Measure ;
  vs:term_status "stable" ;
  vf:layer vf:utility ;
  .

vf:OnhandEffect
  a owl:Class ;
  rdfs:label "Onhand Effect"@en ;
  rdfs:comment "The action has this effect on an inventoried resource onhand quantity."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:Organization
  a owl:Class ;
  rdfs:label "Organization"@en ;
  rdfs:comment "A functional structure, formal or informal, which can include people and/or other organizations, and has its own agency.  Something called a group is an Organization in Valueflows if it has its own agency."@en ;
  rdfs:subClassOf vf:Agent ;
  rdfs:seeAlso org:Organization ;
  vs:term_status "stable" ;
  vf:layer vf:observation ;
  .

vf:Person
  a owl:Class ;
  rdfs:label "Person"@en ;
  rdfs:comment "A human being. All persons are considered agents."@en ;
  rdfs:subClassOf vf:Agent ;
  rdfs:seeAlso foaf:Person ;
  vs:term_status "stable" ;
  vf:layer vf:observation ;
  .

vf:Plan
  a owl:Class ;
  rdfs:label "Plan"@en ;
  rdfs:comment "A logical collection of processes that constitute a body of scheduled work with defined deliverable(s)."@en ;
  vs:term_status "stable" ;
  vf:layer vf:plan ;
  .

vf:Process
  a owl:Class ;
  rdfs:label "Process"@en ;
  rdfs:comment "An activity that changes inputs into outputs, by transforming or transporting economic resource(s)."@en ;
  vs:term_status "stable" ;
  vf:layer vf:observation ;
  .

vf:ProcessSpecification
  a owl:Class ;
  rdfs:label "Process Specification"@en ;
  rdfs:comment "Specifies the kind of process."@en ;
  vs:term_status "stable" ;
  vf:layer vf:knowledge ;
  .

vf:Proposal
  a owl:Class ;
  rdfs:label "Proposal"@en ;
  rdfs:comment "Published requests or offers, sometimes with what is expected in return."@en ;
  vs:term_status "stable" ;
  vf:layer vf:plan ;
  .

vf:ProposalList
  a owl:Class ;
  rdfs:label "Proposal List"@en ;
  rdfs:comment "A grouping of proposals, for publishing as a list."@en ;
  vs:term_status "unstable" ;
  vf:layer vf:plan ;
  .

vf:ProposalPurpose
  a owl:Class ;
  rdfs:label "Proposal Purpose"@en ;
  rdfs:comment "The type of proposal: offer or request (other types may be added)."@en ;
  vs:term_status "testing" ;
  vf:layer vf:plan ;
  .

vf:Recipe
  a owl:Class ;
  rdfs:label "Recipe"@en ;
  rdfs:comment "Optional instance of a recipe which directly specifies the recipe processes included."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:RecipeExchange
  a owl:Class ;
  rdfs:label "Recipe Exchange"@en ;
  rdfs:comment "Specifies an exchange type agreement as part of a recipe."@en ;
  vs:term_status "stable" ;
  vf:layer vf:knowledge ;
  .

vf:RecipeFlow
  a owl:Class ;
  rdfs:label "Recipe Flow"@en ;
  rdfs:comment "The specification of a resource inflow to, or outflow from, a recipe process."@en ;
  vs:term_status "stable" ;
  vf:layer vf:knowledge ;
  .

vf:RecipeGroup
  a owl:Class ;
  rdfs:label "Recipe Group"@en ;
  rdfs:comment "A grouping of recipes to facilitate planning them together."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:RecipeProcess
  a owl:Class ;
  rdfs:label "Recipe Process"@en ;
  rdfs:comment "Specifies a process in a recipe for use in planning from recipe."@en ;
  vs:term_status "stable" ;
  vf:layer vf:knowledge ;
  .

vf:ResourceSpecification
  a owl:Class ;
  rdfs:label "Resource Specification"@en ;
  rdfs:comment "Specifies the kind of resource, even if the resource is not instantiated as an EconomicResource. Could define a material item, service, digital item, currency account, skill or type of work, etc."@en ;
  vs:term_status "stable" ;
  vf:layer vf:knowledge ;
  .

vf:Scenario
  a owl:Class ;
  rdfs:label "Scenario"@en ;
  rdfs:comment "An estimated or analytical logical collection of higher level processes used for budgeting, analysis, plan refinement, etc."@en ;
  vs:term_status "unstable" ;
  vf:layer vf:plan ;
  .

vf:ScenarioDefinition
  a owl:Class ;
  rdfs:label "Scenario Definition"@en ;
  rdfs:comment "The type definition of one or more scenarios."@en ;
  vs:term_status "unstable" ;
  vf:layer vf:knowledge ;
  .

vf:SpatialThing
  a owl:Class ;
  rdfs:label "Spatial Thing"@en ;
  rdfs:comment "Data that locates something relative to the Earth, usually a somewhat fixed location."@en ;
  rdfs:subClassOf geo:SpatialThing ;
  vs:term_status "stable" ;
  vf:layer vf:utility ;
  .

vf:StageEffect
  a owl:Class ;
  rdfs:label "Stage Effect"@en ;
  rdfs:comment "The action has this effect on an inventoried resource stage."@en ;
  vs:term_status "testing" ;
  vf:layer vf:knowledge ;
  .

vf:StateEffect
  a owl:Class ;
  rdfs:label "State Effect"@en ;
  rdfs:comment "The action has this effect on an inventoried resource state."@en ;
  vs:term_status "unstable" ;
  vf:layer vf:knowledge ;
  .

vf:Unit
  a owl:Class ;
  rdfs:label "Unit"@en ;
  rdfs:comment "A standard unit of measure, defined and adopted by convention or by law."@en ;
  rdfs:subClassOf om:Unit ;
  vs:term_status "stable" ;
  vf:layer vf:utility ;
  .

vf:accountableEffect
  a owl:ObjectProperty ;
  rdfs:label "accountable effect"@en ;
  rdfs:comment "The primaryAccountable should be updated to the event receiver, or not."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:AccountableEffect ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:accountingEffect
  a owl:ObjectProperty ;
  rdfs:label "accounting effect"@en ;
  rdfs:comment "The increment and/or decrement effect the action will have on the accounting quantity of an inventoried resource."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:AccountingEffect ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:accountingQuantity
  a owl:ObjectProperty ;
  rdfs:label "accounting quantity"@en ;
  rdfs:comment "The current amount and unit of the economic resource for which the agent has primary rights and responsibilities, sometimes thought of as ownership. This can be either stored or derived from economic events affecting the resource."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range vf:Measure ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:action
  a owl:ObjectProperty ;
  rdfs:label "action"@en ;
  rdfs:comment "Defines the kind of flow, such as consume, produce, work, transfer, etc."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
          vf:RecipeFlow
          vf:Claim
        ) ;
    ] ;
  rdfs:range vf:Action ;
  vs:term_status "stable" ;
  owl:cardinality 1 ;
  .

vf:availableQuantity
  a owl:ObjectProperty ;
  rdfs:label "available quantity"@en ;
  rdfs:comment "The amount and unit of the offered resource currently available."@en ;
  rdfs:domain vf:Intent ;
  rdfs:range vf:Measure ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:basedOn
  a owl:ObjectProperty ;
  rdfs:label "based on"@en ;
  rdfs:comment "The definition or standard specification for a process."@en ;
  rdfs:domain vf:Process ;
  rdfs:range vf:ProcessSpecification ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:bundledIn
  a owl:ObjectProperty ;
  rdfs:label "bundled in"@en ;
  rdfs:comment "This agreement is bundled with other agreements."@en ;
  rdfs:domain vf:Agreement ;
  rdfs:range vf:AgreementBundle ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:bundles
  a owl:ObjectProperty ;
  rdfs:label "bundles"@en ;
  rdfs:comment "All the agreements included in this agreement bundle."@en ;
  rdfs:domain vf:AgreementBundle ;
  rdfs:range vf:Agreement ;
  vs:term_status "testing" ;
  owl:inverseOf vf:bundledIn ;
  .

vf:classifiedAs
  a owl:ObjectProperty ;
  rdfs:label "classified as"@en ;
  rdfs:comment "References one or more uri's for a concept in a common taxonomy or other classification scheme for purposes of categorization or grouping; or can be one or more string classifications."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Process
          vf:EconomicResource
          vf:Organization
          vf:EcologicalAgent
          vf:Unit
        ) ;
    ] ;
  rdfs:range xsd:string ;
  vs:term_status "unstable" ;
  .

vf:clauseOf
  a owl:ObjectProperty ;
  rdfs:label "clause of"@en ;
  rdfs:comment "This commitment is a primary part of the agreement."@en ;
  rdfs:domain vf:Commitment ;
  rdfs:range vf:Agreement ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:conformsTo
  a owl:ObjectProperty ;
  rdfs:label "conforms to"@en ;
  rdfs:comment "The primary resource knowledge specification or definition of an existing or potential resource."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range vf:ResourceSpecification ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:containedEffect
  a owl:ObjectProperty ;
  rdfs:label "contained effect"@en ;
  rdfs:comment "The contained in resource should be updated or removed."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:ContainedEffect ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:containedIn
  a owl:ObjectProperty ;
  rdfs:label "contained in"@en ;
  rdfs:comment "Used when an economic resource contains units also defined as separate economic resources, for example a tool kit or a package of resources for shipping."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range vf:EconomicResource ;
  vs:term_status "unstable" ;
  owl:maxCardinality 1 ;
  .

vf:corrects
  a owl:ObjectProperty ;
  rdfs:label "corrects"@en ;
  rdfs:comment "Used when an event was entered incorrectly and needs to be backed out or corrected. (The initial event cannot be changed.)"@en ;
  rdfs:domain vf:EconomicEvent ;
  rdfs:range vf:EconomicEvent ;
  vs:term_status "unstable" ;
  owl:maxCardinality 1 ;
  .

vf:createResource
  a owl:ObjectProperty ;
  rdfs:label "can create resource"@en ;
  rdfs:comment "The action can create an economic resource."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:CreateResource ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:currentLocation
  a owl:ObjectProperty ;
  rdfs:label "current location"@en ;
  rdfs:comment "The current physical location of an economic resource.  Could be at any level of granularity, from a town to an address to a warehouse location.  Usually mappable."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range vf:SpatialThing ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:defaultUnitOfEffort
  a owl:ObjectProperty ;
  rdfs:label "default unit of effort"@en ;
  rdfs:comment "The default unit used for use or work."@en ;
  rdfs:domain vf:ResourceSpecification ;
  rdfs:range vf:Unit ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:defaultUnitOfResource
  a owl:ObjectProperty ;
  rdfs:label "default unit of resource"@en ;
  rdfs:comment "The default unit used for the resource itself."@en ;
  rdfs:domain vf:ResourceSpecification ;
  rdfs:range vf:Unit ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:definedAs
  a owl:ObjectProperty ;
  rdfs:label "defined as"@en ;
  rdfs:comment "The scenario definition for this scenario, for example yearly budget."@en ;
  rdfs:domain vf:Scenario ;
  rdfs:range vf:ScenarioDefinition ;
  vs:term_status "unstable" ;
  owl:maxCardinality 1 ;
  .

vf:effortQuantity
  a owl:ObjectProperty ;
  rdfs:label "effort quantity"@en ;
  rdfs:comment "The amount and unit of the work or use or citation effort-based action. This is often expressed with a time unit, but also could be cycle counts or other measures of effort or usefulness."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
          vf:RecipeFlow
          vf:Claim
        ) ;
    ] ;
  rdfs:range vf:Measure ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:eligibleLocation
  a owl:ObjectProperty ;
  rdfs:label "eligible location"@en ;
  rdfs:comment "Location or area where the proposal is valid."@en ;
  rdfs:domain vf:Proposal ;
  rdfs:range vf:SpatialThing ;
  vs:term_status "unstable" ;
  owl:maxCardinality 1 ;
  .

vf:eventQuantity
  a owl:ObjectProperty ;
  rdfs:label "event quantity"@en ;
  rdfs:comment "The event quantity applicable is resource quantity, effort quantity, or both."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:EventQuantity ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:fulfills
  a owl:ObjectProperty ;
  rdfs:label "fulfills"@en ;
  rdfs:comment "The commitment which is completely or partially fulfilled by an economic event."@en ;
  rdfs:domain vf:EconomicEvent ;
  rdfs:range vf:Commitment ;
  vs:term_status "testing" ;
  .

vf:hasDetailedGeometry
  a owl:ObjectProperty ;
  rdfs:label "currency address"@en ;
  rdfs:comment "A spatial geometry of any complexity and tooling supported by geosparql."@en ;
  rdfs:domain vf:SpatialThing ;
  rdfs:range geosparql:Geometry ;
  vs:term_status "unstable" ;
  .

vf:hasDuration
  a owl:ObjectProperty ;
  rdfs:label "has duration"@en ;
  rdfs:comment "The temporal extent of the process or scenario."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:RecipeProcess
          vf:ScenarioDefinition
        ) ;
    ] ;
  rdfs:range vf:Measure ;
  rdfs:seeAlso time:hasDuration ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:hasIndependentDemand
  a owl:ObjectProperty ;
  rdfs:label "has independent demand"@en ;
  rdfs:comment "The commitments and/or intents which this plan was created to deliver."@en ;
  rdfs:domain vf:Plan ;
  rdfs:range
    [
      owl:unionOf
        (
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  vs:term_status "testing" ;
  owl:inverseOf vf:independentDemandOf ;
  .

vf:hasInput
  a owl:ObjectProperty ;
  rdfs:label "has input"@en ;
  rdfs:comment "All the input flows of a process."@en ;
  rdfs:domain vf:Process ;
  rdfs:range
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  vs:term_status "testing" ;
  owl:inverseOf vf:inputOf ;
  .

vf:hasOutput
  a owl:ObjectProperty ;
  rdfs:label "has output"@en ;
  rdfs:comment "All the output flows of a process."@en ;
  rdfs:domain vf:Process ;
  rdfs:range
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  vs:term_status "testing" ;
  owl:inverseOf vf:outputOf ;
  .

vf:hasRecipeInput
  a owl:ObjectProperty ;
  rdfs:label "has recipe input"@en ;
  rdfs:comment "All the inputs of a recipe process."@en ;
  rdfs:domain vf:RecipeProcess ;
  rdfs:range vf:RecipeFlow ;
  vs:term_status "testing" ;
  owl:inverseOf vf:recipeInputOf ;
  .

vf:hasRecipeOutput
  a owl:ObjectProperty ;
  rdfs:label "has recipe output"@en ;
  rdfs:comment "All the outputs of a recipe process."@en ;
  rdfs:domain vf:RecipeProcess ;
  rdfs:range vf:RecipeFlow ;
  vs:term_status "testing" ;
  owl:inverseOf vf:recipeOutputOf ;
  .

vf:hasUnit
  a owl:ObjectProperty ;
  rdfs:label "has unit"@en ;
  rdfs:comment "A standard unit of measure."@en ;
  rdfs:subPropertyOf om:hasUnit ;
  rdfs:domain vf:Measure ;
  rdfs:range vf:Unit ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:inScopeOf
  a owl:ObjectProperty ;
  rdfs:label "in scope of"@en ;
  rdfs:comment "Scope here means in the context of an agent."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Claim
          vf:Commitment
          vf:EconomicEvent
          vf:Intent
          vf:Scenario
          vf:Process
          vf:AgentRelationship
        ) ;
    ] ;
  rdfs:range vf:Agent ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:independentDemandOf
  a owl:ObjectProperty ;
  rdfs:label "independent demand of"@en ;
  rdfs:comment "This plan is the way this commitment or intent will be realized."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  rdfs:range vf:Plan ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:inputOf
  a owl:ObjectProperty ;
  rdfs:label "input of"@en ;
  rdfs:comment "Relates an input flow to its process."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  rdfs:range vf:Process ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:inputOutput
  a owl:ObjectProperty ;
  rdfs:label "input/output"@en ;
  rdfs:comment "Denotes if a process input or output, or not applicable to a process."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:InputOutput ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:layer
  a owl:ObjectProperty ;
  rdfs:label "layer"@en ;
  rdfs:comment "A concept layer of the ontology."@en ;
  rdfs:range vf:ConceptLayer ;
  vs:term_status "unstable" ;
  .

vf:listedIn
  a owl:ObjectProperty ;
  rdfs:label "listed in"@en ;
  rdfs:comment "This proposal is part of a list of proposals."@en ;
  rdfs:domain vf:Proposal ;
  rdfs:range vf:ProposalList ;
  vs:term_status "testing" ;
  .

vf:lists
  a owl:ObjectProperty ;
  rdfs:label "lists"@en ;
  rdfs:comment "All the proposals included in this proposal list."@en ;
  rdfs:domain vf:ProposalList ;
  rdfs:range vf:Proposal ;
  vs:term_status "testing" ;
  owl:inverseOf vf:listedIn ;
  .

vf:locationEffect
  a owl:ObjectProperty ;
  rdfs:label "location effect"@en ;
  rdfs:comment "This action can update the current location of an inventoried resource."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:LocationEffect ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:minimumQuantity
  a owl:ObjectProperty ;
  rdfs:label "minimum quantity"@en ;
  rdfs:comment "The minimum required order amount and unit of the offered resource."@en ;
  rdfs:domain vf:Intent ;
  rdfs:range vf:Measure ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:nestedIn
  a owl:ObjectProperty ;
  rdfs:label "nested in"@en ;
  rdfs:comment "The process with its inputs and outputs, or intent, is part of the scenario."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Process
          vf:Intent
          vf:EconomicEvent
        ) ;
    ] ;
  rdfs:range vf:Scenario ;
  vs:term_status "unstable" ;
  .

vf:object
  a owl:ObjectProperty ;
  rdfs:label "object"@en ;
  rdfs:comment "The object of a relationship between 2 agents.  For example, if Mary is a member of a group, then the group is the object."@en ;
  rdfs:domain vf:AgentRelationship ;
  rdfs:range vf:Agent ;
  rdfs:seeAlso as:object ;
  vs:term_status "stable" ;
  owl:cardinality 1 ;
  .

vf:onhandEffect
  a owl:ObjectProperty ;
  rdfs:label "onhand effect"@en ;
  rdfs:comment "The increment and/or decrement effect the action will have on the onhand quantity of an inventoried resource."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:OnhandEffect ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:onhandQuantity
  a owl:ObjectProperty ;
  rdfs:label "onhand quantity"@en ;
  rdfs:comment "The current amount and unit of the economic resource which is under direct control of the agent.  It may be more or less than the accounting quantity. This can be either stored or derived from economic events affecting the resource."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range vf:Measure ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:outputOf
  a owl:ObjectProperty ;
  rdfs:label "output of"@en ;
  rdfs:comment "Relates an output flow to its process."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  rdfs:range vf:Process ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:pairsWith
  a owl:ObjectProperty ;
  rdfs:label "pairs with"@en ;
  rdfs:comment "The action that usually affects the same resource as a complement in the same flow."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:Action ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:planIncludes
  a owl:ObjectProperty ;
  rdfs:label "plan includes"@en ;
  rdfs:comment "The processes and and non-process commitments/intents that constitute the plan."@en ;
  rdfs:domain vf:Plan ;
  rdfs:range
    [
      owl:unionOf
        (
          vf:Process
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  vs:term_status "testing" ;
  owl:inverseOf vf:plannedWithin ;
  .

vf:plannedTogether
  a owl:ObjectProperty ;
  rdfs:label "planned together"@en ;
  rdfs:comment "A collection of recipes that can be planned together."@en ;
  rdfs:domain vf:RecipeGroup ;
  rdfs:range vf:Recipe ;
  vs:term_status "unstable" ;
  .

vf:plannedWithin
  a owl:ObjectProperty ;
  rdfs:label "planned within"@en ;
  rdfs:comment "The process with its inputs and outputs, or the non-process commitment or intent, is part of the plan."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Process
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  rdfs:range vf:Plan ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:primaryAccountable
  a owl:ObjectProperty ;
  rdfs:label "primary accountable"@en ;
  rdfs:comment "The agent currently with primary rights and responsibilites for the economic resource. It is the agent that is associated with the accountingQuantity of the economic resource."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range vf:Agent ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:primaryLocation
  a owl:ObjectProperty ;
  rdfs:label "primary location"@en ;
  rdfs:comment "The main place an agent is located, often an address where activities occur and mail can be sent. This is usually a mappable geographic location."@en ;
  rdfs:domain vf:Agent ;
  rdfs:range vf:SpatialThing ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:primaryOutput
  a owl:ObjectProperty ;
  rdfs:label "primary output"@en ;
  rdfs:comment "The main output the recipe is intended to produce or deliver."@en ;
  rdfs:domain vf:Recipe ;
  rdfs:range vf:ResourceSpecification ;
  vs:term_status "unstable" ;
  owl:maxCardinality 1 ;
  .

vf:processClassifiedAs
  a owl:ObjectProperty ;
  rdfs:label "process classified as"@en ;
  rdfs:comment "References one or more uri's for a concept in a common taxonomy or other classification scheme for purposes of categorization or grouping; or can be one or more string classifications."@en ;
  rdfs:domain vf:RecipeProcess ;
  rdfs:range xsd:string ;
  vs:term_status "unstable" ;
  .

vf:processConformsTo
  a owl:ObjectProperty ;
  rdfs:label "process conforms to"@en ;
  rdfs:comment "The standard specification or definition of a process."@en ;
  rdfs:domain vf:RecipeProcess ;
  rdfs:range vf:ProcessSpecification ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:proposedTo
  a owl:ObjectProperty ;
  rdfs:label "proposed to"@en ;
  rdfs:comment "The agent(s) to which the proposal or proposal list is published."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Proposal
          vf:ProposalList
        ) ;
    ] ;
  rdfs:range vf:Agent ;
  vs:term_status "unstable" ;
  .

vf:provider
  a owl:ObjectProperty ;
  rdfs:label "provider"@en ;
  rdfs:comment "The economic agent by whom the intended, committed, or actual economic event is initiated."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
          vf:Claim
        ) ;
    ] ;
  rdfs:range vf:Agent ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:publishedTo
  a owl:ObjectProperty ;
  rdfs:label "published to"@en ;
  rdfs:comment "The agent(s) to which the scenario is published."@en ;
  rdfs:domain vf:Scenario ;
  rdfs:range vf:Agent ;
  vs:term_status "unstable" ;
  .

vf:publishes
  a owl:ObjectProperty ;
  rdfs:label "publishes"@en ;
  rdfs:comment "The primary intent(s) of this published proposal. Would be used in intent matching."@en ;
  rdfs:domain vf:Proposal ;
  rdfs:range vf:Intent ;
  vs:term_status "testing" ;
  .

vf:purpose
  a owl:ObjectProperty ;
  rdfs:label "purpose"@en ;
  rdfs:comment "The type of proposal, whether offer or request."@en ;
  rdfs:domain vf:Proposal ;
  rdfs:range vf:ProposalPurpose ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:realizationOf
  a owl:ObjectProperty ;
  rdfs:label "realization of"@en ;
  rdfs:comment "This non-reciprocal economic event occurs as part of this agreement."@en ;
  rdfs:domain vf:EconomicEvent ;
  rdfs:range vf:Agreement ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:realizes
  a owl:ObjectProperty ;
  rdfs:label "realizes"@en ;
  rdfs:comment "All the non-reciprocal economic events (with or without commitments) that realize the agreement."@en ;
  rdfs:domain vf:Agreement ;
  rdfs:range vf:EconomicEvent ;
  vs:term_status "testing" ;
  owl:inverseOf vf:realizationOf ;
  .

vf:realizesReciprocal
  a owl:ObjectProperty ;
  rdfs:label "realizes reciprocal"@en ;
  rdfs:comment "All the reciprocal economic events (with or without commitments) that realize the agreement."@en ;
  rdfs:domain vf:Agreement ;
  rdfs:range vf:EconomicEvent ;
  vs:term_status "testing" ;
  owl:inverseOf vf:reciprocalRealizationOf ;
  .

vf:receiver
  a owl:ObjectProperty ;
  rdfs:label "receiver"@en ;
  rdfs:comment "The economic agent whom the intended, committed, or actual economic event is for."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
          vf:Claim
        ) ;
    ] ;
  rdfs:range vf:Agent ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:recipeClauseOf
  a owl:ObjectProperty ;
  rdfs:label "recipe clause of"@en ;
  rdfs:comment "Relates a flow to its exchange agreement in a recipe."@en ;
  rdfs:domain vf:RecipeFlow ;
  rdfs:range vf:RecipeExchange ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:recipeIncludes
  a owl:ObjectProperty ;
  rdfs:label "recipe includes"@en ;
  rdfs:comment "The collection of processes needed for this recipe."@en ;
  rdfs:domain vf:Recipe ;
  rdfs:range vf:RecipeProcess ;
  vs:term_status "unstable" ;
  .

vf:recipeInputOf
  a owl:ObjectProperty ;
  rdfs:label "recipe input of"@en ;
  rdfs:comment "Relates an input flow to its process in a recipe."@en ;
  rdfs:domain vf:RecipeFlow ;
  rdfs:range vf:RecipeProcess ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:recipeOutputOf
  a owl:ObjectProperty ;
  rdfs:label "recipe output of"@en ;
  rdfs:comment "Relates an output flow to its process in a recipe."@en ;
  rdfs:domain vf:RecipeFlow ;
  rdfs:range vf:RecipeProcess ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:recipeReciprocalClauseOf
  a owl:ObjectProperty ;
  rdfs:label "recipe reciprocal clause of"@en ;
  rdfs:comment "Relates a reciprocal flow to its exchange agreement in a recipe."@en ;
  rdfs:domain vf:RecipeFlow ;
  rdfs:range vf:RecipeExchange ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:recipeStipulates
  a owl:ObjectProperty ;
  rdfs:label "recipe stipulates"@en ;
  rdfs:comment "All the primary clauses of a recipe exchange."@en ;
  rdfs:domain vf:RecipeExchange ;
  rdfs:range vf:RecipeFlow ;
  vs:term_status "testing" ;
  owl:inverseOf vf:recipeClauseOf ;
  .

vf:recipeStipulatesReciprocal
  a owl:ObjectProperty ;
  rdfs:label "recipe stipulates reciprocal"@en ;
  rdfs:comment "All the reciprocal clauses of a recipe exchange."@en ;
  rdfs:domain vf:RecipeExchange ;
  rdfs:range vf:RecipeFlow ;
  vs:term_status "testing" ;
  owl:inverseOf vf:recipeReciprocalClauseOf ;
  .

vf:reciprocal
  a owl:ObjectProperty ;
  rdfs:label "reciprocal"@en ;
  rdfs:comment "The reciprocal intent(s) of this published proposal. Not meant to be used for intent matching."@en ;
  rdfs:domain vf:Proposal ;
  rdfs:range vf:Intent ;
  vs:term_status "testing" ;
  .

vf:reciprocalClauseOf
  a owl:ObjectProperty ;
  rdfs:label "reciprocal clause of"@en ;
  rdfs:comment "This commitment is a reciprocal part of the agreement."@en ;
  rdfs:domain vf:Commitment ;
  rdfs:range vf:Agreement ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:reciprocalRealizationOf
  a owl:ObjectProperty ;
  rdfs:label "reciprocal realization of"@en ;
  rdfs:comment "This reciprocal economic event occurs as part of this agreement."@en ;
  rdfs:domain vf:EconomicEvent ;
  rdfs:range vf:Agreement ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:refinementOf
  a owl:ObjectProperty ;
  rdfs:label "refinement of"@en ;
  rdfs:comment "This scenario or plan refines another scenario, often as time moves closer or for more detail."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Scenario
          vf:Plan
        ) ;
    ] ;
  rdfs:range vf:Scenario ;
  vs:term_status "unstable" ;
  .

vf:relationship
  a owl:ObjectProperty ;
  rdfs:label "relationship"@en ;
  rdfs:comment "The role of an economic relationship that exists between 2 agents, such as member, trading partner."@en ;
  rdfs:domain vf:AgentRelationship ;
  rdfs:range vf:AgentRelationshipRole ;
  rdfs:seeAlso as:relationship ;
  vs:term_status "stable" ;
  owl:cardinality 1 ;
  .

vf:resourceClassifiedAs
  a owl:ObjectProperty ;
  rdfs:label "resource classified as"@en ;
  rdfs:comment "References one or more uri's for a concept in a common taxonomy or other classification scheme for purposes of categorization or grouping; or can be one or more string classifications."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:ResourceSpecification
          vf:RecipeFlow
          vf:Intent
          vf:Commitment
          vf:EconomicEvent
          vf:Claim
        ) ;
    ] ;
  rdfs:range xsd:string ;
  vs:term_status "unstable" ;
  .

vf:resourceConformsTo
  a owl:ObjectProperty ;
  rdfs:label "resource conforms to"@en ;
  rdfs:comment "The primary resource specification or definition of an existing or potential economic resource. A resource will have only one, as this specifies exactly what the resource is."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Commitment
          vf:Intent
          vf:EconomicEvent
          vf:Claim
          vf:RecipeFlow
        ) ;
    ] ;
  rdfs:range vf:ResourceSpecification ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:resourceInventoriedAs
  a owl:ObjectProperty ;
  rdfs:label "resource inventoried as"@en ;
  rdfs:comment "Economic resource involved in the flow."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Commitment
          vf:Intent
          vf:EconomicEvent
        ) ;
    ] ;
  rdfs:range vf:EconomicResource ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:resourceQuantity
  a owl:ObjectProperty ;
  rdfs:label "resource quantity"@en ;
  rdfs:comment "The amount and unit of the economic resource counted or inventoried."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicEvent
          vf:Commitment
          vf:Intent
          vf:RecipeFlow
          vf:Claim
        ) ;
    ] ;
  rdfs:range vf:Measure ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:satisfies
  a owl:ObjectProperty ;
  rdfs:label "satisfies"@en ;
  rdfs:comment "An intent satisfied fully or partially by an economic event or commitment."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Commitment
          vf:EconomicEvent
        ) ;
    ] ;
  rdfs:range vf:Intent ;
  vs:term_status "testing" ;
  .

vf:scenarioIncludes
  a owl:ObjectProperty ;
  rdfs:label "scenario includes"@en ;
  rdfs:comment "The processes and and/or intents that constitute the plan."@en ;
  rdfs:domain vf:Scenario ;
  rdfs:range
    [
      owl:unionOf
        (
          vf:Process
          vf:Intent
        ) ;
    ] ;
  vs:term_status "testing" ;
  owl:inverseOf vf:nestedIn ;
  .

vf:settles
  a owl:ObjectProperty ;
  rdfs:label "settles"@en ;
  rdfs:comment "References a claim that is fully or partially settled by the economic event."@en ;
  rdfs:domain vf:EconomicEvent ;
  rdfs:range vf:Claim ;
  vs:term_status "testing" ;
  .

vf:stage
  a owl:ObjectProperty ;
  rdfs:label "stage"@en ;
  rdfs:comment "The required stage of the desired input economic resource. References the ProcessSpecification of the last process the economic resource went through."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicResource
          vf:Commitment
          vf:Intent
          vf:RecipeFlow
        ) ;
    ] ;
  rdfs:range vf:ProcessSpecification ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:stageEffect
  a owl:ObjectProperty ;
  rdfs:label "stage effect"@en ;
  rdfs:comment "The stage of the inventoried resource should be updated, or not."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:StageEffect ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:state
  a owl:ObjectProperty ;
  rdfs:label "state"@en ;
  rdfs:comment "The required state of the desired input economic resource, after coming out of a test or review process."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:EconomicResource
          vf:EconomicEvent
          vf:RecipeFlow
          vf:Commitment
          vf:Intent
        ) ;
    ] ;
  rdfs:range xsd:string ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:stateEffect
  a owl:ObjectProperty ;
  rdfs:label "state effect"@en ;
  rdfs:comment "The state of the from or to inventoried resource should be updated, or not."@en ;
  rdfs:domain vf:Action ;
  rdfs:range vf:StateEffect ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:stipulates
  a owl:ObjectProperty ;
  rdfs:label "stipulates"@en ;
  rdfs:comment "All the primary commitments that constitute the agreement."@en ;
  rdfs:domain vf:Agreement ;
  rdfs:range vf:Commitment ;
  vs:term_status "testing" ;
  owl:inverseOf vf:clauseOf ;
  .

vf:stipulatesReciprocal
  a owl:ObjectProperty ;
  rdfs:label "stipulates reciprocal"@en ;
  rdfs:comment "All the reciprocal commitments that constitute the agreement."@en ;
  rdfs:domain vf:Agreement ;
  rdfs:range vf:Commitment ;
  vs:term_status "testing" ;
  owl:inverseOf vf:reciprocalClauseOf ;
  .

vf:subject
  a owl:ObjectProperty ;
  rdfs:label "subject"@en ;
  rdfs:comment "The subject of a relationship between 2 agents.  For example, if Mary is a member of a group, then Mary is the subject."@en ;
  rdfs:domain vf:AgentRelationship ;
  rdfs:range vf:Agent ;
  rdfs:seeAlso as:subject ;
  vs:term_status "stable" ;
  owl:cardinality 1 ;
  .

vf:toLocation
  a owl:ObjectProperty ;
  rdfs:label "to location"@en ;
  rdfs:comment "The new location of the receiver resource."@en ;
  rdfs:domain vf:EconomicEvent ;
  rdfs:range vf:SpatialThing ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:toResourceInventoriedAs
  a owl:ObjectProperty ;
  rdfs:label "to resource inventoried as"@en ;
  rdfs:comment "Additional economic resource on the economic event when needed by the receiver. Used when a transfer or move, or sometimes other actions, requires explicitly identifying an economic resource by the receiver, which is identified differently by the sender."@en ;
  rdfs:domain vf:EconomicEvent ;
  rdfs:range vf:EconomicResource ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:triggeredBy
  a owl:ObjectProperty ;
  rdfs:label "triggered by"@en ;
  rdfs:comment "References an economic event that implied the claim, often based on a prior agreement."@en ;
  rdfs:domain vf:Claim ;
  rdfs:range vf:EconomicEvent ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:unitOfEffort
  a owl:ObjectProperty ;
  rdfs:label "unit of effort"@en ;
  rdfs:comment "The unit used for use or work or sometimes cite actions."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range vf:Unit ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:alt
  a owl:DatatypeProperty ;
  rdfs:comment "The WGS84 altitude of a spatial thing (decimal meters above the local reference ellipsoid)" ;
  rdfs:subPropertyOf geo:alt ;
  rdfs:domain vf:SpatialThing ;
  rdfs:range dtype:numericUnion ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:created
  a owl:DatatypeProperty ;
  rdfs:label "created"@en ;
  rdfs:comment "The date, and time if desired, the information was agreed to or recorded."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Agreement
          vf:Claim
          vf:Commitment
          vf:Plan
          vf:Proposal
          vf:Scenario
          vf:EconomicEvent
        ) ;
    ] ;
  rdfs:range xsd:dateTimeStamp ;
  rdfs:seeAlso dcterms:created ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:currentCurrencyLocation
  a owl:DatatypeProperty ;
  rdfs:label "current currency location"@en ;
  rdfs:comment "The current virtual place a currency economic resource is located, for example the address for a bank account, crypto wallet, etc., in a domain standard format."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range xsd:string ;
  vs:term_status "unstable" ;
  owl:maxCardinality 1 ;
  .

vf:currentVirtualLocation
  a owl:DatatypeProperty ;
  rdfs:label "current virtual location"@en ;
  rdfs:comment "The current virtual place a digital economic resource is located. Usually used for documents, code, or other electronic resource."@en ;
  rdfs:domain vf:EconomicResource ;
  rdfs:range xsd:anyURI ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:due
  a owl:DatatypeProperty ;
  rdfs:label "due"@en ;
  rdfs:comment "The time something is expected to be complete."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Plan
          vf:Commitment
          vf:Claim
          vf:Intent
        ) ;
    ] ;
  rdfs:range xsd:dateTimeStamp ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:finished
  a owl:DatatypeProperty ;
  rdfs:label "finished"@en ;
  rdfs:comment "The commitment or intent or process is complete or not.  This is irrespective of if the original goal has been met, and indicates that no more will be done.  Default false."@en ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Commitment
          vf:Process
          vf:Intent
          vf:Claim
        ) ;
    ] ;
  rdfs:range xsd:boolean ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:hasBeginning
  a owl:DatatypeProperty ;
  rdfs:label "has beginning"@en ;
