  vf:accountableEffect vf:updateTo ;
  vf:accountingEffect vf:decrementIncrement ;
  vf:containedEffect vf:notApplicable ;
  vf:createResource vf:optionalTo ;
  vf:eventQuantity vf:resource ;
  vf:inputOutput vf:notApplicable ;
  vf:locationEffect vf:notApplicable ;
  vf:onhandEffect vf:notApplicable ;
  vf:pairsWith vf:notApplicable ;
  vf:stageEffect vf:notApplicable ;
  vf:stateEffect vf:updateTo ;
  .

