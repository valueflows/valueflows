vf:label
  a owl:DataTypeProperty ;
  rdfs:label "label"@en ;
  rdfs:comment "The display label defined in om for the unit of measure."@en ;
  rdfs:subPropertyOf rdfs:label ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Unit
          vf:Action
        ) ;
    ] ;
  rdfs:range xsd:string ;
  vs:term_status "stable" ;
  owl:cardinality 1 ;
  .

vf:note
  a owl:DataTypeProperty ;
  rdfs:label "note"@en ;
  rdfs:comment "Any useful textual information related to the item."@en ;
  rdfs:subPropertyOf skos:note ;
  rdfs:domain
    [
      owl:unionOf
        (
          vf:Agent
          vf:AgentRelationship
          vf:AgentRelationshipRole
          vf:Agreement
          vf:Claim
          vf:Commitment
          vf:EconomicEvent
          vf:EconomicResource
          vf:ExternalLink
          vf:Intent
          vf:Plan
          vf:Process
          vf:ProcessSpecification
          vf:Proposal
          vf:Recipe
          vf:RecipeFlow
          vf:RecipeGroup
          vf:RecipeProcess
          vf:ResourceSpecification
          vf:Scenario
          vf:ScenarioDefinition
          vf:SpatialThing
        ) ;
    ] ;
  rdfs:range xsd:string ;
  vs:term_status "stable" ;
  owl:maxCardinality 1 ;
  .

vf:omUnitIdentifier
  a owl:DataTypeProperty ;
  rdfs:label "om unit identifier"@en ;
  rdfs:comment "The unique identifier of the om unit of measure, for standardization across networks."@en ;
  rdfs:domain vf:Unit ;
  rdfs:range xsd:anyURI ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:overrideLabel
  a owl:DataTypeProperty ;
  rdfs:label "override label"@en ;
  rdfs:comment "An optional network override label to display for units of measure if the original is less appropriate."@en ;
  rdfs:domain vf:Unit ;
  rdfs:range xsd:string ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:overrideSymbol
  a owl:DataTypeProperty ;
  rdfs:label "override symbol"@en ;
  rdfs:comment "An optional network override symbol to display for units of measure if the original is less appropriate."@en ;
  rdfs:domain vf:Unit ;
  rdfs:range xsd:string ;
  vs:term_status "testing" ;
  owl:maxCardinality 1 ;
  .

vf:rules
  a owl:DataTypeProperty ;
  rdfs:label "rules"@en ;
  rdfs:comment "The rules or contract that govern this agreement."@en ;
  rdfs:domain vf:Agreement ;
  rdfs:range xsd:anyURI ;
  vs:term_status "unstable" ;
  .

vf:symbol
  a owl:DataTypeProperty ;
  rdfs:label "symbol"@en ;
  rdfs:comment "The display symbol defined in om for the unit of measure."@en ;
